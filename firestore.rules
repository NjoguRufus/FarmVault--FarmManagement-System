// Firestore security rules for FarmVault
// You can keep evolving these as we add more features.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Safely load the authenticated user's companyId (handles missing user doc or missing field).
    function userCompanyId() {
      let userRef = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userRef) ? get(userRef).data.get('companyId', null) : null;
    }

    // CompanyId from user doc, or from auth token custom claims (for payment flows when user doc may be stale).
    function effectiveUserCompanyId() {
      let fromDoc = userCompanyId();
      return fromDoc != null ? fromDoc : request.auth.token.get('companyId', null);
    }

    // For creates: ensure the new document's companyId matches the user's companyId.
    function matchesCompanyOnCreate() {
      return isSignedIn()
        && request.resource.data.get('companyId', null) == userCompanyId();
    }

    // For updates/deletes: ensure the existing doc's companyId matches the user's companyId.
    function matchesCompanyOnDoc() {
      return isSignedIn()
        && resource.data.get('companyId', null) == userCompanyId();
    }

    function isDeveloper() {
      let userRef = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() && exists(userRef)
        && get(userRef).data.get('role', null) == 'developer';
    }

    function isCompanyAdmin() {
      let userRef = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() && exists(userRef)
        && (get(userRef).data.get('role', null) == 'company-admin'
            || get(userRef).data.get('role', null) == 'company_admin');
    }

    function isManager() {
      let userRef = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() && exists(userRef) && (
        get(userRef).data.get('role', null) == 'manager'
        || get(userRef).data.get('employeeRole', null) == 'manager'
        || get(userRef).data.get('employeeRole', null) == 'operations-manager'
      );
    }

    // Read company-scoped docs: only when doc.companyId matches user's companyId, or developer.
    // Prevents leaking docs with companyId == null to normal users.
    function canReadCompanyDoc() {
      return isSignedIn() && (
        (userCompanyId() != null && resource.data.get('companyId', null) == userCompanyId())
        || isDeveloper()
      );
    }

    // --- Users ---
    // Read: own doc, or same-company docs (for listing company users).
    // Write: own doc; company-admin/developer can create/update same-company docs. companyId must not change on update.
    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId
        || (userCompanyId() != null && resource.data.get('companyId', null) == userCompanyId())
      );
      allow create: if isSignedIn() && (
        request.auth.uid == userId
        || (isCompanyAdmin() && request.resource.data.get('companyId', null) == userCompanyId())
        || isDeveloper()
      );
      allow update: if isSignedIn() && (
        request.auth.uid == userId
        || (isCompanyAdmin() && request.resource.data.get('companyId', null) == userCompanyId())
        || isDeveloper()
      ) && request.resource.data.get('companyId', null) == resource.data.get('companyId', null);
      allow delete: if isSignedIn() && (request.auth.uid == userId || isDeveloper());
    }

    // --- Companies ---

    match /companies/{companyId} {
      // Create: any signed-in user (onboarding has no user doc yet, so userCompanyId() is null).
      // Read/update/delete: only own company or developer.
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn() && (userCompanyId() == companyId || isDeveloper());
    }

    // --- Projects ---

    match /projects/{projectId} {
      allow read: if canReadCompanyDoc();
      allow update, delete: if isSignedIn() && (matchesCompanyOnDoc() || isDeveloper());
      allow create: if isSignedIn() && (matchesCompanyOnCreate() || isDeveloper());
    }

    // --- Project Stages ---

    match /projectStages/{stageId} {
      allow read: if canReadCompanyDoc();
      allow update, delete: if isSignedIn() && (matchesCompanyOnDoc() || isDeveloper());
      allow create: if isSignedIn() && (matchesCompanyOnCreate() || isDeveloper());
    }

    // --- Stage Notes (company + project + stage scoped) ---
    match /stageNotes/{noteId} {
      allow read: if isSignedIn() && (resource.data.get('companyId', null) == userCompanyId() || isDeveloper());
      allow create: if isSignedIn() && request.resource.data.get('companyId', null) == userCompanyId();
    }

    // --- Project Blocks (company + project scoped) ---

    match /projectBlocks/{blockId} {
      allow read: if isSignedIn() && (resource.data.get('companyId', null) == userCompanyId() || isDeveloper());
      allow create: if isSignedIn() && request.resource.data.get('companyId', null) == userCompanyId();
      allow update, delete: if isSignedIn() && (resource.data.get('companyId', null) == userCompanyId() || isDeveloper());
    }

    // --- Budget Pools (company scoped) ---

    match /budgetPools/{poolId} {
      allow read: if isSignedIn() && (resource.data.get('companyId', null) == userCompanyId() || isDeveloper());
      allow create: if isSignedIn() && request.resource.data.get('companyId', null) == userCompanyId();
      allow update, delete: if isSignedIn() && (resource.data.get('companyId', null) == userCompanyId() || isDeveloper());
    }

    // --- Work Logs ---

    match /workLogs/{workLogId} {
      allow read: if canReadCompanyDoc();
      allow update, delete: if isSignedIn() && (matchesCompanyOnDoc() || isDeveloper());
      allow create: if isSignedIn() && (matchesCompanyOnCreate() || isDeveloper());
    }

    // --- Operations Work Cards (Admin creates; Manager submits execution only) ---
    match /operationsWorkCards/{cardId} {
      allow read: if isSignedIn() && (resource.data.get('companyId', null) == userCompanyId() || isDeveloper());
      allow create: if isSignedIn() && (matchesCompanyOnCreate() || isDeveloper());
      allow update, delete: if isSignedIn() && (matchesCompanyOnDoc() || isDeveloper());
    }

    // --- Expenses ---

    match /expenses/{expenseId} {
      allow read: if canReadCompanyDoc();
      allow update, delete: if isSignedIn() && (matchesCompanyOnDoc() || isDeveloper());
      allow create: if isSignedIn() && (
        isDeveloper()
        || (request.resource.data.get('companyId', null) != null
            && (request.resource.data.get('companyId', null) == userCompanyId()
                || request.resource.data.get('companyId', null) == effectiveUserCompanyId()))
      );
    }

    // --- Season Challenges ---

    match /seasonChallenges/{challengeId} {
      allow read: if canReadCompanyDoc();
      allow update, delete: if isSignedIn() && (matchesCompanyOnDoc() || isDeveloper());
      allow create: if isSignedIn() && (matchesCompanyOnCreate() || isDeveloper());
    }

    // --- Challenge Templates (reusable pre-season, company + crop scoped) ---
    match /challengeTemplates/{templateId} {
      allow read: if isSignedIn() && (resource.data.get('companyId', null) == userCompanyId() || isDeveloper());
      allow create, update: if isSignedIn() && request.resource.data.get('companyId', null) == userCompanyId();
    }

    // --- Inventory Usage ---

    match /inventoryUsage/{usageId} {
      allow read: if canReadCompanyDoc();
      allow update, delete: if isSignedIn() && (matchesCompanyOnDoc() || isDeveloper());
      allow create: if isSignedIn() && (matchesCompanyOnCreate() || isDeveloper());
    }

    // --- Inventory Items ---

    match /inventoryItems/{itemId} {
      allow read: if canReadCompanyDoc();
      allow update, delete: if isSignedIn() && (matchesCompanyOnDoc() || isDeveloper());
      allow create: if isSignedIn() && (matchesCompanyOnCreate() || isDeveloper());
    }

    // --- Inventory Categories ---

    match /inventoryCategories/{categoryId} {
      allow read: if canReadCompanyDoc();
      allow update, delete: if isSignedIn() && (matchesCompanyOnDoc() || isDeveloper());
      allow create: if isSignedIn() && (matchesCompanyOnCreate() || isDeveloper());
    }

    // --- Inventory Purchases ---

    match /inventoryPurchases/{purchaseId} {
      allow read: if canReadCompanyDoc();
      allow update, delete: if isSignedIn() && (matchesCompanyOnDoc() || isDeveloper());
      allow create: if isSignedIn() && (matchesCompanyOnCreate() || isDeveloper());
    }

    // --- Harvests ---

    match /harvests/{harvestId} {
      allow read: if canReadCompanyDoc();
      allow update, delete: if isSignedIn() && (matchesCompanyOnDoc() || isDeveloper());
      allow create: if isSignedIn() && (matchesCompanyOnCreate() || isDeveloper());
    }

    // --- Harvest Collections (field cash: pickers + weigh + buyer) ---
    // Use effectiveUserCompanyId so payments keep working even if user doc is slightly stale
    match /harvestCollections/{collectionId} {
      allow read: if isSignedIn() && (
        isDeveloper() 
        || (resource.data.get('companyId', null) != null 
            && (resource.data.get('companyId', null) == userCompanyId()
                || resource.data.get('companyId', null) == effectiveUserCompanyId()))
      );
      
      // Allow create for signed-in users with matching companyId
      allow create: if isSignedIn() && (
        isDeveloper()
        || (request.resource.data.get('companyId', null) != null 
            && (request.resource.data.get('companyId', null) == userCompanyId()
                || request.resource.data.get('companyId', null) == effectiveUserCompanyId()))
      );
      
      // Allow update for any signed-in user from the same company (for marking payments, closing collection, etc.)
      allow update: if isSignedIn() && (
        isDeveloper()
        || (resource.data.get('companyId', null) != null 
            && (resource.data.get('companyId', null) == userCompanyId()
                || resource.data.get('companyId', null) == effectiveUserCompanyId()))
      );
      
      // Delete only for developers or company admins
      allow delete: if isSignedIn() && (isCompanyAdmin() || isDeveloper());
    }

    match /harvestPickers/{pickerId} {
      allow read: if isSignedIn() && (
        isDeveloper() 
        || (resource.data.get('companyId', null) != null 
            && resource.data.get('companyId', null) == userCompanyId())
        || (resource.data.get('companyId', null) != null 
            && resource.data.get('companyId', null) == effectiveUserCompanyId())
        || (resource.data.get('collectionId', null) != null
            && exists(/databases/$(database)/documents/harvestCollections/$(resource.data.collectionId))
            && (get(/databases/$(database)/documents/harvestCollections/$(resource.data.collectionId)).data.get('companyId', null) == userCompanyId()
                || get(/databases/$(database)/documents/harvestCollections/$(resource.data.collectionId)).data.get('companyId', null) == effectiveUserCompanyId()))
      );
      
      allow create: if isSignedIn() && (
        isDeveloper()
        || (request.resource.data.get('companyId', null) != null 
            && (request.resource.data.get('companyId', null) == userCompanyId()
                || request.resource.data.get('companyId', null) == effectiveUserCompanyId()))
      );
      
      allow update: if isSignedIn() && (
        isDeveloper()
        || (resource.data.get('companyId', null) != null 
            && (resource.data.get('companyId', null) == userCompanyId()
                || resource.data.get('companyId', null) == effectiveUserCompanyId()))
        || (resource.data.get('collectionId', null) != null
            && effectiveUserCompanyId() != null
            && exists(/databases/$(database)/documents/harvestCollections/$(resource.data.collectionId))
            && get(/databases/$(database)/documents/harvestCollections/$(resource.data.collectionId)).data.get('companyId', null) == effectiveUserCompanyId())
      );
      
      allow delete: if isSignedIn() && (isCompanyAdmin() || isDeveloper());
    }

    match /pickerWeighEntries/{entryId} {
      allow read: if isSignedIn() && (
        isDeveloper() 
        || (resource.data.get('companyId', null) != null 
            && resource.data.get('companyId', null) == userCompanyId())
      );
      
      allow create: if isSignedIn() && (
        isDeveloper()
        || (request.resource.data.get('companyId', null) != null 
            && request.resource.data.get('companyId', null) == userCompanyId())
      );
      
      allow update: if isSignedIn() && (
        isDeveloper()
        || (resource.data.get('companyId', null) != null 
            && resource.data.get('companyId', null) == userCompanyId())
      );
      
      allow delete: if isSignedIn() && (isCompanyAdmin() || isDeveloper());
    }

    match /harvestPaymentBatches/{batchId} {
      allow read: if isSignedIn() && (
        isDeveloper() 
        || (resource.data.get('companyId', null) != null 
            && (resource.data.get('companyId', null) == userCompanyId()
                || resource.data.get('companyId', null) == effectiveUserCompanyId()))
      );
      
      allow create: if isSignedIn() && (
        isDeveloper()
        || (request.resource.data.get('companyId', null) != null 
            && (request.resource.data.get('companyId', null) == userCompanyId()
                || request.resource.data.get('companyId', null) == effectiveUserCompanyId()))
      );
      
      allow update: if isSignedIn() && (
        isDeveloper()
        || (resource.data.get('companyId', null) != null 
            && (resource.data.get('companyId', null) == userCompanyId()
                || resource.data.get('companyId', null) == effectiveUserCompanyId()))
      );
      
      allow delete: if isSignedIn() && (isCompanyAdmin() || isDeveloper());
    }

    // --- Sales ---

    match /sales/{saleId} {
      allow read: if canReadCompanyDoc();
      allow update, delete: if isSignedIn() && (matchesCompanyOnDoc() || isDeveloper());
      allow create: if isSignedIn() && (matchesCompanyOnCreate() || isDeveloper());
    }

    // --- Harvest Cash Pools (French beans legacy per-collection wallet) ---
    match /harvestCashPools/{poolId} {
      allow read: if canReadCompanyDoc();
      allow update, delete: if isSignedIn() && (matchesCompanyOnDoc() || isDeveloper());
      allow create: if isSignedIn() && (matchesCompanyOnCreate() || isDeveloper());
    }

    // --- Harvest Wallets (single master harvest wallet per project/crop) ---
    match /harvestWallets/{walletId} {
      allow read: if canReadCompanyDoc();
      allow update, delete: if isSignedIn() && (matchesCompanyOnDoc() || isDeveloper());
      allow create: if isSignedIn() && (matchesCompanyOnCreate() || isDeveloper());
    }

    // --- Collection cash usage for harvest wallet deductions ---
    // Tracks how much each harvest collection has deducted from its master wallet.
    match /collectionCashUsage/{usageId} {
      allow read: if canReadCompanyDoc();
      allow update, delete: if isSignedIn() && (matchesCompanyOnDoc() || isDeveloper());
      allow create: if isSignedIn() && (matchesCompanyOnCreate() || isDeveloper());
    }

    // --- Project Wallet Ledger (append-only project cash ledger) ---
    match /projectWalletLedger/{entryId} {
      allow read: if isSignedIn() && (
        isDeveloper()
        || (resource.data.get('companyId', null) != null
            && (resource.data.get('companyId', null) == userCompanyId()
                || resource.data.get('companyId', null) == effectiveUserCompanyId()))
      );
      allow create: if isSignedIn() && (
        isDeveloper()
        || (request.resource.data.get('companyId', null) != null
            && (request.resource.data.get('companyId', null) == userCompanyId()
                || request.resource.data.get('companyId', null) == effectiveUserCompanyId()))
      );
      allow update, delete: if false;
    }

    // --- Project Wallet Migration Meta ---
    // Document ID format: companyId_projectId
    match /projectWalletMeta/{metaId} {
      allow read: if isSignedIn() && (
        isDeveloper()
        || (userCompanyId() != null && metaId.matches('^' + userCompanyId() + '_.*'))
        || (effectiveUserCompanyId() != null && metaId.matches('^' + effectiveUserCompanyId() + '_.*'))
      );
      allow create: if isSignedIn() && (
        isDeveloper()
        || request.resource.data.get('companyId', null) == userCompanyId()
        || request.resource.data.get('companyId', null) == effectiveUserCompanyId()
        || (request.resource.data.get('companyId', null) == null
            && userCompanyId() != null
            && metaId.matches('^' + userCompanyId() + '_.*'))
        || (request.resource.data.get('companyId', null) == null
            && effectiveUserCompanyId() != null
            && metaId.matches('^' + effectiveUserCompanyId() + '_.*'))
      );
      allow update: if isSignedIn() && (
        isDeveloper()
        || resource.data.get('companyId', null) == userCompanyId()
        || resource.data.get('companyId', null) == effectiveUserCompanyId()
        || (resource.data.get('companyId', null) == null
            && userCompanyId() != null
            && metaId.matches('^' + userCompanyId() + '_.*'))
        || (resource.data.get('companyId', null) == null
            && effectiveUserCompanyId() != null
            && metaId.matches('^' + effectiveUserCompanyId() + '_.*'))
      );
      allow delete: if false;
    }

    // --- Suppliers ---

    match /suppliers/{supplierId} {
      allow read: if canReadCompanyDoc();
      allow update, delete: if isSignedIn() && (matchesCompanyOnDoc() || isDeveloper());
      allow create: if isSignedIn() && (matchesCompanyOnCreate() || isDeveloper());
    }

    // --- Crop Catalog (custom crop knowledge per company) ---
    match /cropCatalog/{cropId} {
      allow read: if isSignedIn() && (matchesCompanyOnDoc() || isDeveloper());
      allow update, delete: if isSignedIn() && (matchesCompanyOnDoc() || isDeveloper());
      allow create: if isSignedIn() && (matchesCompanyOnCreate() || isDeveloper());
    }

    // --- Custom Roles ---
    // Company-scoped custom role definitions (for permission presets/templates in-app).
    // Expected field: companyId
    match /customRoles/{roleId} {
      allow read: if isSignedIn() && (matchesCompanyOnDoc() || isDeveloper());
      allow update, delete: if isSignedIn() && (matchesCompanyOnDoc() || isDeveloper());
      allow create: if isSignedIn() && (matchesCompanyOnCreate() || isDeveloper());
    }

    // --- Employees ---
    // Create: company-admin or manager (same company only), or developer. Requester's user doc must have companyId for company match.
    // Allow read when doc doesn't exist so AuthContext can safely getDoc(employees/uid) for new users with no employee record.
    match /employees/{employeeId} {
      allow read: if isSignedIn() && (
        !exists(/databases/$(database)/documents/employees/$(employeeId))
        || canReadCompanyDoc()
        || resource.data.get('authUserId', null) == request.auth.uid
      );
      allow update, delete: if isSignedIn() && (matchesCompanyOnDoc() || isDeveloper());
      allow create: if isSignedIn() && (
        (isCompanyAdmin() && request.resource.data.get('companyId', null) == userCompanyId())
        || (isManager() && request.resource.data.get('companyId', null) == userCompanyId())
        || isDeveloper()
      );
    }

    // --- Deliveries ---

    match /deliveries/{deliveryId} {
      allow read: if canReadCompanyDoc();
      allow update, delete: if isSignedIn() && (matchesCompanyOnDoc() || isDeveloper());
      allow create: if isSignedIn() && (matchesCompanyOnCreate() || isDeveloper());
    }

    // --- Needed Items ---

    match /neededItems/{itemId} {
      allow read: if canReadCompanyDoc();
      allow update, delete: if isSignedIn() && (matchesCompanyOnDoc() || isDeveloper());
      allow create: if isSignedIn() && (matchesCompanyOnCreate() || isDeveloper());
    }

    // --- Feedback ---

    match /feedback/{feedbackId} {
      allow read: if canReadCompanyDoc();
      allow update, delete: if isSignedIn() && (matchesCompanyOnDoc() || isDeveloper());
      allow create: if isSignedIn() && (matchesCompanyOnCreate() || isDeveloper());
    }

    // --- Company data backups: developer can read/write any; company-admin can read/write own company only ---
    match /developerBackups/{companyId} {
      allow read, write: if isDeveloper() || (isSignedIn() && userCompanyId() == companyId);
      match /snapshots/{snapshotId} {
        allow read, write: if isDeveloper() || (isSignedIn() && userCompanyId() == companyId);
      }
    }

    // --- Platform expenses: FarmVault (developer) operational expenses ---
    match /platformExpenses/{expenseId} {
      allow read: if isDeveloper();
      allow create: if isDeveloper();
      allow update: if isDeveloper();
      allow delete: if isDeveloper();
    }

    // --- Audit logs: create allowed for any signed-in user (app records WORK_CREATED etc.); read developer-only ---
    match /auditLogs/{logId} {
      allow read: if isDeveloper();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // --- Inventory audit logs: who did what (restock/deduct/delete/add); company users create and read their own ---
    match /inventoryAuditLogs/{logId} {
      allow create: if isSignedIn() && (
        request.resource.data.get('companyId', null) == userCompanyId()
        || isDeveloper()
      );
      allow read: if isSignedIn() && (
        resource.data.get('companyId', null) == userCompanyId()
        || isDeveloper()
      );
      allow update, delete: if false;
    }

    // --- Activity logs: live operations snapshot (tasks, harvest, inventory, payments) ---
    match /activityLogs/{logId} {
      allow create: if isSignedIn() && (
        request.resource.data.get('companyId', null) == userCompanyId()
        || isDeveloper()
      );
      allow read: if isSignedIn() && (
        resource.data.get('companyId', null) == userCompanyId()
        || isDeveloper()
      );
      allow update, delete: if false;
    }

    // --- Crops (reference list for notes; developer can write, all read) ---
    match /crops/{cropId} {
      allow read: if isSignedIn();
      allow write: if isDeveloper();
    }

    // --- Notes library (global; developer only) ---
    match /notes_library/{noteId} {
      allow read, write: if isDeveloper();
    }

    // --- Company note shares (developer shares to company; company can read own) ---
    match /company_note_shares/{shareId} {
      allow read: if isSignedIn() && (
        isDeveloper() || resource.data.get('companyId', null) == userCompanyId()
      );
      allow create, update, delete: if isDeveloper();
    }

    // --- Company notes (company-created; company admin CRUD own, developer read all) ---
    match /company_notes/{noteId} {
      allow read: if isSignedIn() && (
        isDeveloper() || resource.data.get('companyId', null) == userCompanyId()
      );
      allow create: if isSignedIn() && isCompanyAdmin()
        && request.resource.data.get('companyId', null) == userCompanyId();
      allow update, delete: if isSignedIn() && (
        isDeveloper()
        || (resource.data.get('companyId', null) == userCompanyId() && isCompanyAdmin())
      );
    }

    // --- Code Red: urgent developer–admin communication (e.g. data recovery) ---
    match /codeRed/{requestId} {
      allow read: if isSignedIn() && (
        resource.data.get('companyId', null) == userCompanyId() || isDeveloper()
      );
      allow create: if isSignedIn() && request.resource.data.get('companyId', null) == userCompanyId();
      allow update, delete: if isSignedIn() && (  
        resource.data.get('companyId', null) == userCompanyId() || isDeveloper()
      );
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && (
          get(/databases/$(database)/documents/codeRed/$(requestId)).data.get('companyId', null) == userCompanyId()
          || isDeveloper()
        );
      }
    }

    // --- Fallback: deny everything else by default ---

    match /{document=**} {
      allow read, write: if false;
    }
  }
}