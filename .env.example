# Copy to `.env` (local only). Do NOT commit real secrets.
#
# This app uses Clerk + Supabase; most values below are public-ish (VITE_*) except API keys/secrets.

# Supabase (public client config)
VITE_ONBOARDING_PROVIDER=supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Clerk (public)
VITE_CLERK_PUBLISHABLE_KEY=

# Developer gating / emergency access (treat as sensitive)
VITE_ENABLE_DEV_GATEWAY=true
VITE_DEV_EMAIL_ALLOWLIST=
VITE_EMERGENCY_ACCESS=false
VITE_EMERGENCY_EMAIL=
VITE_EMERGENCY_USER_ID=
VITE_EMERGENCY_COMPANY_ID=
VITE_EMERGENCY_ROLE=

# Tenant / URLs
VITE_APP_BASE_URL=
VITE_PUBLIC_BASE_URL=
VITE_PUBLIC_APP_URL=

# WhatsApp activation
VITE_FARMVAULT_ACTIVATION_WHATSAPP=
VITE_WHATSAPP_ACTIVATION_NUMBER=

# Resend (secret)
VITE_RESEND_API_KEY=

# PostHog (usually public, but keep out of git if you prefer)
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=
VITE_PUBLIC_POSTHOG_HOST=

# M-Pesa Daraja (used by Supabase Edge Functions)
# Set MPESA_ENV to `sandbox` or `production` and provide matching credentials.
MPESA_ENV=sandbox
MPESA_SHORTCODE=
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=

# OneSignal (web push + server-side notification dispatch)
ONESIGNAL_APP_ID=c9bda911-e3a1-4b12-a1c3-0eab892c4d5a
ONESIGNAL_REST_API_KEY=
ONESIGNAL_INTERNAL_NOTIFY_SECRET=

