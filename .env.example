# Copy to `.env` (local only). Do NOT commit real secrets.
#
# This app uses Clerk + Supabase; most values below are public-ish (VITE_*) except API keys/secrets.

# Postgres URI for Phase 0 backups (`npm run backup:db`) — direct/session connection; NEVER use VITE_ prefix.
# DATABASE_URL=

# Supabase (public client config)
VITE_ONBOARDING_PROVIDER=supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Clerk (public)
VITE_CLERK_PUBLISHABLE_KEY=

# Developer gating (treat as sensitive in production)
VITE_ENABLE_DEV_GATEWAY=true
VITE_DEV_EMAIL_ALLOWLIST=

# Emergency access (Phase 1): configure ONLY as Supabase Edge Function secrets on `emergency-access` — never VITE_*.
#   EMERGENCY_ACCESS_ENABLED=true | EMERGENCY_ACCESS_SECRET | EMERGENCY_ALLOWED_EMAILS (comma-separated)
#   EMERGENCY_SESSION_USER_ID | EMERGENCY_SESSION_COMPANY_ID | EMERGENCY_SESSION_ROLE (optional, default company_admin)
# Stuck STK reconciliation: Edge `mpesa-payment-reconcile` + MPESA_RECONCILE_SECRET (Bearer).
# Optional pg_cron: migration `20260412230000_sprint1_mpesa_reconcile_pg_cron.sql` + Vault secrets
#   `mpesa_reconcile_project_url`, `mpesa_reconcile_bearer_secret` (same value as MPESA_RECONCILE_SECRET).
#
# M-Pesa callback: in production, Daraja STK Query must confirm success before subscription activation unless disabled:
#   MPESA_VERIFY_SUCCESS_WITH_STK_QUERY=false   (sandbox-friendly explicit off)
#   MPESA_VERIFY_SUCCESS_WITH_STK_QUERY=true    (force verify in any MPESA_ENV)
#   (unset) — defaults to verify ON when MPESA_ENV=production, OFF in sandbox.

# Tenant / URLs
VITE_APP_BASE_URL=
VITE_PUBLIC_BASE_URL=
VITE_PUBLIC_APP_URL=

# WhatsApp activation
VITE_FARMVAULT_ACTIVATION_WHATSAPP=
VITE_WHATSAPP_ACTIVATION_NUMBER=

# Resend — set as Supabase Edge secret RESEND_API_KEY only (never VITE_* — not exposed to browser).
# RESEND_API_KEY=

# PostHog (usually public, but keep out of git if you prefer)
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=
VITE_PUBLIC_POSTHOG_HOST=

# M-Pesa Daraja (used by Supabase Edge Functions)
# Set MPESA_ENV to `sandbox` or `production` and provide matching credentials.
MPESA_ENV=sandbox
MPESA_SHORTCODE=
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=

# OneSignal (web push + server-side notification dispatch)
ONESIGNAL_APP_ID=c9bda911-e3a1-4b12-a1c3-0eab892c4d5a
ONESIGNAL_REST_API_KEY=
ONESIGNAL_INTERNAL_NOTIFY_SECRET=

