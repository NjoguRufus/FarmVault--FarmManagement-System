rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ---- Helpers ----
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // ---- User private uploads ----
    // Store user files here:
    // user_uploads/{uid}/...
    match /user_uploads/{uid}/{allPaths=**} {
      allow read, write: if isOwner(uid);
    }

    // ---- Optional public assets (ONLY if you need it) ----
    // e.g. app icons, marketing images
    // Put files here:
    // public/{allPaths=**}
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // ---- Default deny ----
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}